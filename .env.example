# Copia este archivo a ".env" y rellena tus claves. Reinicia "npm run dev" tras cambiarlo.

# --- Recetas: Spoonacular --- https://spoonacular.com/food-api
VITE_SPOONACULAR_API_KEY=tu_clave_spoonacular

# Los ejercicios (free-exercise-db) y la traducción (gtx/MyMemory) no necesitan clave.

# --- Supabase --- https://supabase.com  (Settings > API)
VITE_SUPABASE_URL=https://TU-PROYECTO.supabase.co
VITE_SUPABASE_ANON_KEY=tu_clave_anon_publica
