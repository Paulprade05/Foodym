# Copia este archivo a ".env" y rellena tus claves. Reinicia "npm run dev" tras cambiarlo.

# --- Recetas: Spoonacular --- https://spoonacular.com/food-api
VITE_SPOONACULAR_API_KEY=tu_clave_spoonacular

# Los ejercicios (free-exercise-db) y la traducción (MyMemory) no necesitan clave.

# --- Firebase --- Consola: https://console.firebase.google.com
# Project settings > General > Tus apps > SDK setup and configuration
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
